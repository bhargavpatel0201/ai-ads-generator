# Neon PostgreSQL (app data: users, video_projects) — also put this in server/.env (the API only reads server/.env)
# If you used the old Clerk schema, rename column clerk_id -> auth_user_id and clear or remap rows; then run: npm run db:push (from server/)
# Error "Database not configured" = missing or empty DATABASE_URL in server/.env. See: server/.env.example
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Supabase Auth — client + API must use the SAME project (anon key, not the service_role key)
# If sign-in says "email not confirmed": check inbox, use "Resend confirmation" on /sign-in, or for local dev
# turn off "Confirm email" under Authentication → Providers → Email in the Supabase dashboard.
# See: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
# Optional: show Google / GitHub / Discord buttons. Set true only after each provider is enabled in the Supabase dashboard
# (else /auth/v1/authorize returns 400 "provider is not enabled"). Google: Providers → Google → enable + Client ID/Secret;
# in Google Cloud add redirect https://<project-ref>.supabase.co/auth/v1/callback ; URL Configuration must allow http://localhost:5173/**
# VITE_SHOW_OAUTH=true
# Required on the server for JWT validation; copy the same two values (without VITE_ prefix):
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...

# Stripe — copy real values into server/.env only (never commit real keys). See server/.env.example.
# STRIPE_SECRET_KEY       = Secret key from Stripe Dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET   = Webhook signing secret (Dashboard → Webhooks)
# STRIPE_PRICE_ID_PRO     = Price ID for Pro plan (starts with price_)
# STRIPE_PRICE_ID_PREMIUM = Price ID for Premium plan

# Gemini AI
GEMINI_API_KEY=AIza...

# Sentry
VITE_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...

# App
CLIENT_URL=http://localhost:5173
PORT=5000
