# Copy to .env (never commit .env). For Vercel: add the same VITE_* keys under Settings → Environment Variables, then redeploy.

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Required on Vercel / production: Render (or other) API URL.
# You may set either https://YOUR-SERVICE.onrender.com or https://YOUR-SERVICE.onrender.com/api — /api is added if missing.
# VITE_API_URL=https://ai-ads-api.onrender.com

# Canonical browser origin for OAuth/email redirects (production).
# VITE_SITE_URL=https://www.yourdomain.com

# VITE_SHOW_OAUTH=true
