# Copy to .env (never commit .env). For Vercel: add the same VITE_* keys under Settings → Environment Variables, then redeploy.

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Required on Vercel / production: your Node API public URL — must end with /api (same path prefix as Express).
# Example after deploying server to Render:
# VITE_API_URL=https://ai-ads-api-xxxx.onrender.com/api
# Leave unset for local dev; Vite proxies /api to the server (see vite.config.js).
# VITE_API_URL=

# Canonical browser origin for OAuth/email redirects (production).
# VITE_SITE_URL=https://www.yourdomain.com

# VITE_SHOW_OAUTH=true
