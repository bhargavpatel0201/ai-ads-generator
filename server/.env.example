    # Copy to server/.env and fill values. The API loads this file automatically.
    #
    # Neon: Dashboard → your project → Connection string → "URI" (include ?sslmode=require)
    # Must be one line, full URI after = — a blank "DATABASE_URL=" will cause "Database not configured"
    DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

    SUPABASE_URL=https://xxxx.supabase.co
    SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

    # Gemini — Google AI Studio (https://aistudio.google.com/apikey) → "Create API key"
    GEMINI_API_KEY=
    # TEXT: use flash-lite by default for better free-tier availability.
    # Alternatives:
    #   GEMINI_TEXT_MODEL=gemini-2.5-flash
    #   GEMINI_TEXT_MODEL=gemini-flash-latest
    GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
    #
    # IMAGE PROVIDER:
    #   IMAGE_PROVIDER=gemini      -> best identity lock (supports reference images)
    #   IMAGE_PROVIDER=huggingface -> free text-to-image fallback (ignores uploads)
    IMAGE_PROVIDER=gemini
    #
    # Hugging Face (optional free text-to-image provider)
    # Get key: https://huggingface.co/settings/tokens
    # HUGGINGFACE_API_KEY=hf_...
    HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
    #
    # Gemini image model path:
    # there is currently NO Gemini image model on the free tier — the API
    # returns "limit: 0" for gemini-3.1-flash-image-preview ("Nano Banana"),
    # gemini-2.5-flash-image, and imagen-3.0-* unless billing is enabled at:
    #   https://console.cloud.google.com/billing
    # Until billing is enabled, the server falls back to a free text-to-image URL
    # (default: Pollinations — no API key; optional: picsum for a fast stock JPEG).
    # Uploaded product/model photos are only passed to Gemini; the fallback cannot
    # see them — enable billing for true composition.
    # IMAGE_FALLBACK=pollinations   # or: picsum
    #
    # After enabling billing, pick one:
    #   GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # latest Nano Banana
    #   GEMINI_IMAGE_MODEL=gemini-2.5-flash-image          # previous Nano Banana
    #   GEMINI_IMAGE_MODEL=imagen-3.0-generate-002         # higher fidelity (Imagen)
    GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
    #
    # VIDEO (Veo / image-to-video via ai.models.generateVideos). Requires billing + quota.
    # Override if your Google AI Studio project exposes a newer Veo build:
    # GEMINI_VIDEO_MODEL=veo-3.1-generate-001
    GEMINI_VIDEO_MODEL=veo-2.0-generate-001
    #
    # Optional upgrade for text quality (also requires billing):
    # GEMINI_TEXT_MODEL=gemini-2.5-pro
    #
    # Budget protection (hard monthly caps; set 0 to disable)
    MONTHLY_AD_GENERATION_LIMIT=25
    MONTHLY_VIDEO_GENERATION_LIMIT=25

    CLIENT_URL=http://localhost:5173
    PORT=5000

    # Sentry (optional) — Dashboard → Settings → Projects → Client Keys (DSN). Leave empty to disable.
    # SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
    # SENTRY_TRACES_SAMPLE_RATE=1.0   # 0.0–1.0; lower in prod (e.g. 0.1) to control quota
    # SENTRY_RELEASE=ai-ugc-ads-server@1.0.0   # optional, ties events to a release

    # Stripe — TEST MODE (recommended for local dev: no real money)
    # In Stripe Dashboard, turn “Test mode” ON (top). Only create products/prices in Test mode, then:
    # 1) Developers → API keys: use the Secret that starts with sk_test_ (never sk_live_ in .env for dev)
    # 2) Products → Pro & Premium → monthly price_... ids for STRIPE_PRICE_ID_PRO / STRIPE_PRICE_ID_PREMIUM
    # 3) Webhooks: Stripe CLI for local, or whsec_ from a Test-mode webhook
    # 4) Customer portal: can be set up in test mode
    # The server logs “[stripe] test mode” when STRIPE_SECRET_KEY starts with sk_test_.
    # STRIPE_SECRET_KEY=sk_test_...
    # STRIPE_WEBHOOK_SECRET=whsec_...
    # STRIPE_PRICE_ID_PRO=price_...
    # STRIPE_PRICE_ID_PREMIUM=price_...
